generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("users")
}

model News {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  date      String
  imageUrl  String?  @map("image_url")
  slug      String?  @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("news")
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  date        String
  location    String
  description String
  imageUrl    String?  @map("image_url")
  slug        String?  @unique
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("events")
}

model Station {
  id          Int      @id @default(autoincrement())
  name        String
  genre       String
  description String
  streaming   Boolean  @default(false)
  imageUrl    String?  @map("image_url")
  slug        String?  @unique
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("stations")
}

model Page {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  title       String
  content     String?
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("pages")
}

model ListeningSession {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userAddress  String    @map("user_address")
  startTime    DateTime  @map("start_time") @db.Timestamptz(6)
  endTime      DateTime? @map("end_time") @db.Timestamptz(6)
  duration     Int?      @default(0)
  stationId    String?   @map("station_id")
  verified     Boolean?  @default(false)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("listening_sessions")
  @@index([userAddress], map: "idx_listening_sessions_user")
}

model UserStats {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userAddress           String    @unique @map("user_address")
  totalListeningTime    Int?      @default(0) @map("total_listening_time")
  verifiedListeningTime Int?      @default(0) @map("verified_listening_time")
  totalRewardsClaimed   String?   @default("0") @map("total_rewards_claimed")
  lastRewardClaim       DateTime? @map("last_reward_claim") @db.Timestamptz(6)
  createdAt             DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("user_stats")
  @@index([userAddress], map: "idx_user_stats_user")
}

model RewardClaim {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userAddress   String    @map("user_address")
  listeningTime Int       @map("listening_time")
  rewardAmount  String    @map("reward_amount")
  signature     String
  nonce         Int
  claimed       Boolean?  @default(false)
  txHash        String?   @map("tx_hash")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("reward_claims")
  @@index([userAddress], map: "idx_reward_claims_user")
}

model RateLimiting {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userAddress String    @map("user_address")
  actionType  String    @map("action_type")
  lastAction  DateTime? @default(now()) @map("last_action") @db.Timestamptz(6)
  actionCount Int?      @default(1) @map("action_count")
  createdAt   DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("rate_limiting")
  @@unique([userAddress, actionType])
}

model MusicTweet {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tweetId     String      @unique @map("tweet_id")
  username    String
  handle      String
  content     String
  avatarUrl   String?     @map("avatar_url")
  songRequest String?     @map("song_request")
  processed   Boolean?    @default(false)
  createdAt   DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  MusicQueue  MusicQueue[]

  @@map("music_tweets")
}

model MusicQueue {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tweetId        String?     @map("tweet_id")
  title          String
  artist         String
  videoId        String?     @map("video_id")
  thumbnailUrl   String?     @map("thumbnail_url")
  duration       String?
  requestedBy    String      @map("requested_by")
  queuePosition  Int?        @map("queue_position")
  status         String?     @default("pending")
  createdAt      DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  Tweet          MusicTweet? @relation(fields: [tweetId], references: [tweetId])
  NowPlaying     NowPlaying[]

  @@map("music_queue")
}

model NowPlaying {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  songId    String?     @map("song_id") @db.Uuid
  isPlaying Boolean?    @default(false) @map("is_playing")
  volume    Int?        @default(100)
  startedAt DateTime?   @default(now()) @map("started_at") @db.Timestamptz(6)
  updatedAt DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  Song      MusicQueue? @relation(fields: [songId], references: [id])

  @@map("now_playing")
}

model RentalListing {
  id                Int       @id @default(autoincrement())
  tokenId           Int       @map("token_id")
  lender            String
  pricePerHour      Decimal   @map("price_per_hour") @db.Decimal
  maxDurationHours  Int       @map("max_duration_hours")
  isActive          Boolean?  @default(true) @map("is_active")
  isSuperAccess     Boolean?  @default(false) @map("is_super_access")
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("rental_listings")
}
